### 가격 분석 결과 카드

```tsx
// 제품 식별
<h2 className="text-xl font-bold">
  {brandName} — {innEn}
</h2>

// 수출 적합성 판정 뱃지
<span className={`px-3 py-1 rounded-full text-sm font-semibold text-white
  ${grade.startsWith('A') ? 'bg-emerald-500' :
    grade.startsWith('B') ? 'bg-blue-500' :
    grade.startsWith('D') ? 'bg-amber-500' : 'bg-red-500'}`}>
  {verdict}
</span>

// 참조 정보 2-column
<div className="grid grid-cols-2 gap-4">
  <div className="bg-gray-50 rounded-lg p-4">
    <p className="text-xs text-gray-500">참조가 (원문)</p>
    <p className="text-sm">{referencePrice}</p>
  </div>
  <div className="bg-gray-50 rounded-lg p-4">
    <p className="text-xs text-gray-500">적용 환율 (실시간 EXIM)</p>
    <p className="text-sm">1 USD = 1 PAB (고정) / {krwRate} KRW</p>
  </div>
</div>

// 최종 권고 수출가
<div className="bg-blue-50 rounded-lg p-6">
  <span className="text-sm text-gray-500">권고 수출가</span>
  <span className="text-3xl font-bold ml-4">FOB ${fob}</span>
</div>
```

### 가격 시나리오 3-bar

```tsx
// 팀장 디자인: 공격(파랑)/평균(노랑)/보수(빨강) 가로 바
const scenarios = [
  { label: "저가진입", value: penetrationFob, color: "bg-blue-100", textColor: "text-blue-700" },
  { label: "기준가",   value: referenceFob,   color: "bg-amber-100", textColor: "text-amber-700" },
  { label: "프리미엄", value: premiumFob,     color: "bg-red-100",  textColor: "text-red-700" },
];

{scenarios.map(s => (
  <div key={s.label} className={`${s.color} rounded-lg p-4 flex justify-between items-center`}>
    <span className={`text-sm font-semibold ${s.textColor}`}>{s.label}</span>
    <span className="text-xl font-bold">FOB ${s.value.toFixed(2)}</span>
  </div>
))}
```