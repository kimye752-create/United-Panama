/** 파나마 전용 가격 전략 프리셋 — 유통 마진 고정, FOB 배수로 전략 분기 */

export type PricingStrategy = "penetration" | "reference" | "premium" | "custom";
export type MarketChannel = "retail" | "public";

/** 유통 마진 구조 (시장이 정한 팩트, 전략과 무관) */
export interface MarginStructure {
  pharmacyMargin: number;   // 소매: 약국마진 / 공공: 0
  wholesaleMargin: number;  // 소매: 도매마진 / 공공: 에이전트 영업비
  logistics: number;        // 물류/통관비
  risk: number;             // 리스크 상각
}

/** 파나마 유통 마진 고정값 */
export const PANAMA_RETAIL_MARGINS: MarginStructure = {
  pharmacyMargin: 0.25,    // 약국 25%
  wholesaleMargin: 0.20,   // 도매 20%
  logistics: 0.065,        // 물류 6.5%
  risk: 0.02,              // 리스크 2%
};

export const PANAMA_PUBLIC_MARGINS: MarginStructure = {
  pharmacyMargin: 0.00,    // B2G 직납, 약국 없음
  wholesaleMargin: 0.15,   // 에이전트 영업비 15%
  logistics: 0.065,        // 물류 6.5%
  risk: 0.10,              // CSS 대금 지연 리스크 10%
};

/** 전략별 FOB 배수 (FOB 천장에 곱하는 값) */
export const STRATEGY_MULTIPLIERS: Record<Exclude<PricingStrategy, "custom">, number> = {
  penetration: 0.85,       // 자사 15% 양보
  reference: 1.00,         // 시장 허용 그대로
  premium: 1.20,           // 기술 프리미엄 20%
};

/** 파나마 고정 특수성 */
export const PANAMA_FIXED = {
  tariff: 0,               // 한-중미 FTA 관세 0%
  itbms: 0,                // 의약품 ITBMS 0%
  currencyPeg: 1,          // PAB = USD 1:1 (1904~)
} as const;

/** FOB 천장 역산 (유통 마진 제거) */
export function calculateFobCeiling(
  marketPrice: number,
  margins: MarginStructure,
): number {
  return marketPrice
    / (1 + margins.pharmacyMargin)
    / (1 + margins.wholesaleMargin)
    / (1 + margins.logistics)
    / (1 + margins.risk);
}

/** 최종 FOB (천장 × 전략 배수) */
export function calculateFinalFob(
  fobCeiling: number,
  multiplier: number,
): number {
  return fobCeiling * multiplier;
}

/** 현지 소매 포지셔닝가 순산 (최종 FOB → 소매가) */
export function calculatePositioningPrice(
  finalFob: number,
  margins: MarginStructure,
): number {
  return finalFob
    * (1 + margins.risk)
    * (1 + margins.logistics)
    * (1 + margins.wholesaleMargin)
    * (1 + margins.pharmacyMargin);
}

/** Waterfall 역산 단계 (차트용) */
export function calculateReverseWaterfall(
  marketPrice: number,
  margins: MarginStructure,
) {
  const afterPharmacy = marketPrice / (1 + margins.pharmacyMargin);
  const afterWholesale = afterPharmacy / (1 + margins.wholesaleMargin);
  const afterLogistics = afterWholesale / (1 + margins.logistics);
  const fobCeiling = afterLogistics / (1 + margins.risk);

  return [
    { label: "경쟁품 소매가", value: marketPrice, delta: 0, color: "#3B82F6" },
    { label: "약국 마진 공제", value: afterPharmacy, delta: -(marketPrice - afterPharmacy), percent: margins.pharmacyMargin * 100, color: "#EF4444" },
    { label: "도매 마진 공제", value: afterWholesale, delta: -(afterPharmacy - afterWholesale), percent: margins.wholesaleMargin * 100, color: "#F59E0B" },
    { label: "물류/통관 공제", value: afterLogistics, delta: -(afterWholesale - afterLogistics), percent: margins.logistics * 100, color: "#8B5CF6" },
    { label: "리스크 공제", value: fobCeiling, delta: -(afterLogistics - fobCeiling), percent: margins.risk * 100, color: "#6B7280" },
    { label: "FOB 천장", value: fobCeiling, delta: 0, color: "#10B981" },
  ];
}

/** Waterfall 순산 단계 (차트용) */
export function calculateForwardWaterfall(
  finalFob: number,
  margins: MarginStructure,
) {
  const afterRisk = finalFob * (1 + margins.risk);
  const afterLogistics = afterRisk * (1 + margins.logistics);
  const afterWholesale = afterLogistics * (1 + margins.wholesaleMargin);
  const retailPositioning = afterWholesale * (1 + margins.pharmacyMargin);

  return [
    { label: "최종 FOB", value: finalFob, delta: 0, color: "#10B981" },
    { label: "리스크 가산", value: afterRisk, delta: afterRisk - finalFob, percent: margins.risk * 100, color: "#9CA3AF" },
    { label: "물류/통관 가산", value: afterLogistics, delta: afterLogistics - afterRisk, percent: margins.logistics * 100, color: "#A78BFA" },
    { label: "도매 마진 가산", value: afterWholesale, delta: afterWholesale - afterLogistics, percent: margins.wholesaleMargin * 100, color: "#34D399" },
    { label: "약국 마진 가산", value: retailPositioning, delta: retailPositioning - afterWholesale, percent: margins.pharmacyMargin * 100, color: "#10B981" },
    { label: "소매 포지셔닝가", value: retailPositioning, delta: 0, color: "#3B82F6" },
  ];
}
