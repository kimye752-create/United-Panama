# ============================================================
# UPharma Export AI — 환경변수 템플릿
# ============================================================
# 사용법:
#   1. 이 파일을 .env로 복사: copy .env.example .env
#   2. 각 변수의 값을 본인 키로 채우기
#   3. .env는 git에 절대 commit 금지 (.gitignore로 보호됨)
# ============================================================

# === Supabase 백엔드 (크롤러·서버 전용) ===
# 위치: scripts/runners/preload_*.ts, src/seed_loaders/*.ts
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Supabase Next.js 프론트엔드 (브라우저 노출 OK) ===
# 위치: lib/supabase-browser.ts, components/*.tsx
# 주의: NEXT_PUBLIC_ prefix 필수, 값은 SUPABASE_URL/SUPABASE_KEY와 동일
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# === Anthropic API (Phase B 실시간 보강 - 세션 8+) ===
# 사용 시점: freshness_checker가 7일 초과 판정 시 web_search tool 호출
CLAUDE_API_KEY=sk-ant-...

# === Residential Proxy (민간 약국 크롤링 - 세션 8+) ===
# 사용 시점: pa_arrocha.ts / pa_metroplus.ts (Cloudflare WAF 우회)
RESIDENTIAL_PROXY_URL=http://user:pass@proxy:port

# === Optional ===
WORLD_BANK_API_KEY=optional
SLACK_WEBHOOK_URL=optional